# ====================== 核心配置（必填）======================
# 通义千问API密钥，获取地址：https://dashscope.console.aliyun.com/
DASHSCOPE_API_KEY="你的通义千问API密钥"
# 用户专属记忆ID（本地开发用，Docker部署自动忽略）
USER_ID=user1  

# ====================== 目录配置（可选，不填使用默认值）======================
DOCS_DIR=./docs
CACHE_DIR=./cache
CHROMA_RAG_DIR=./chroma_rag_db
CHROMA_MEM_DIR=./chroma_memory_db

# ====================== 文档分割参数（可选）======================
CHUNK_SIZE=512
CHUNK_OVERLAP=126

# ====================== 模型温度参数（可选，范围0-1）======================
RAG_TEMPERATURE=0.1
CHAT_TEMPERATURE=0.7

# ====================== 记忆管理参数（可选）======================
MEMORY_MAX_COUNT=20
MEMORY_EXPIRE_DAYS=30

# ====================== MySQL 配置（Docker部署自动覆盖）======================
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_DATABASE=ai_assistant
MYSQL_USER=ai_assistant
MYSQL_PASSWORD=123456
MYSQL_CHARSET=utf8mb4